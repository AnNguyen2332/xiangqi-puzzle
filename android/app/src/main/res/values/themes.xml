<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CoThe" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorPrimaryVariant">@color/piece_red_border</item>
        <item name="colorOnPrimary">@color/piece_red_text</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="BtnPrimary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/piece_red_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="backgroundTint">@color/accent_red</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:paddingStart">40dp</item>
        <item name="android:paddingEnd">40dp</item>
    </style>

    <style name="BtnSecondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent_gold</item>
        <item name="android:textSize">14sp</item>
        <item name="strokeColor">@color/accent_gold</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">30dp</item>
        <item name="android:paddingEnd">30dp</item>
    </style>
</resources>
