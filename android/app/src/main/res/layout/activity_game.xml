<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Main game UI ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_dark">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:tint="@color/text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/tv_puzzle_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THẾ 1 / 147"
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />

                <TextView
                    android:id="@+id/tv_puzzle_heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chiếu hết trong 1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_puzzle_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/red_moves_first"
                    android:textSize="11sp"
                    android:textColor="@color/accent_gold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Turn indicator -->
        <LinearLayout
            android:id="@+id/turn_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="6dp">

            <View
                android:id="@+id/turn_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_turn_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/turn_red"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0s"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Board -->
        <com.xiangqi.cothe.ui.BoardView
            android:id="@+id/board_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="8dp" />

        <!-- Action row -->
        <LinearLayout
            android:id="@+id/action_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_hint"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:text="💡"
                android:textSize="20sp"
                android:layout_marginEnd="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_undo"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:text="↩"
                android:textSize="20sp"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Progress dots -->
        <LinearLayout
            android:id="@+id/progress_row"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

    <!-- ── Fail overlay ── -->
    <FrameLayout
        android:id="@+id/fail_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_bg"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x2715;"
                android:textSize="40sp"
                android:textColor="@color/accent_red"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fail_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fail_sub"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry"
                style="@style/BtnPrimary"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="@string/btn_retry" />
        </LinearLayout>
    </FrameLayout>

    <!-- ── Win overlay ── -->
    <LinearLayout
        android:id="@+id/win_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_dark"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_win_stamp"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:gravity="center"
            android:text="&#x5C07;"
            android:textSize="60sp"
            android:textColor="@color/accent_red"
            android:fontFamily="serif"
            android:background="@drawable/win_stamp_bg"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/win_eyebrow"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/win_title"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="serif"
            android:layout_marginBottom="28dp" />

        <!-- Win stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/stat_card_bg"
                android:padding="16dp"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/tv_win_moves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/win_moves"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/stat_card_bg"
                android:padding="16dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/tv_win_hints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/win_hints"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/stat_card_bg"
                android:padding="16dp"
                android:layout_marginStart="8dp">
                <TextView
                    android:id="@+id/tv_win_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0s"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/win_time"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/BtnPrimary"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_next"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_replay"
            style="@style/BtnSecondary"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_replay" />

    </LinearLayout>

</FrameLayout>
