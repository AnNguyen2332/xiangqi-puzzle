<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── Main game UI ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── Red header ── -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/header_red"
            android:paddingStart="4dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="14dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:tint="#ffffff" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="4dp">

                <TextView
                    android:id="@+id/tv_puzzle_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THẾ 1"
                    android:textSize="11sp"
                    android:textColor="#ffffffa0"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tv_puzzle_heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chiếu hết trong 1 nước"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff" />

                <TextView
                    android:id="@+id/tv_puzzle_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/red_moves_first"
                    android:textSize="11sp"
                    android:textColor="@color/accent_gold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Turn indicator bar ── -->
        <LinearLayout
            android:id="@+id/turn_indicator"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="#1a000000">

            <View
                android:id="@+id/turn_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tv_turn_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lượt của Đỏ"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0s"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- ── Board (inside card for rounded corners) ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/board_bg"
            app:strokeWidth="0dp">

            <com.xiangqi.cothe.ui.BoardView
                android:id="@+id/board_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Action row: [hint]  [progress dots]  [undo] ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_hint"
                style="@style/BtnIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="💡" />

            <LinearLayout
                android:id="@+id/progress_row"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_undo"
                style="@style/BtnIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:text="↩" />
        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════ -->
    <!-- ── Fail overlay ──                            -->
    <!-- ══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/fail_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_bg"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="40sp"
                android:textColor="@color/accent_red"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fail_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fail_sub"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="28dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry"
                style="@style/BtnPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_retry" />
        </LinearLayout>
    </FrameLayout>

    <!-- ══════════════════════════════════════════════ -->
    <!-- ── Win overlay ──                             -->
    <!-- ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/win_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_dark"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:visibility="gone">

        <!-- 将 stamp icon -->
        <TextView
            android:id="@+id/tv_win_stamp"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:gravity="center"
            android:text="&#x5C07;"
            android:textSize="60sp"
            android:textColor="@color/accent_red"
            android:fontFamily="serif"
            android:background="@drawable/win_stamp_bg"
            android:layout_marginBottom="20dp" />

        <!-- "XUẤT SẮC" eyebrow -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/win_eyebrow"
            android:textAllCaps="true"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/accent_red"
            android:letterSpacing="0.25"
            android:layout_marginBottom="4dp" />

        <!-- "Chiếu Hết!" title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/win_title"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="serif"
            android:layout_marginBottom="32dp" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="36dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/stat_card_bg"
                android:padding="14dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tv_win_moves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/win_moves"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/stat_card_bg"
                android:padding="14dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp">
                <TextView
                    android:id="@+id/tv_win_hints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/win_hints"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/stat_card_bg"
                android:padding="14dp"
                android:layout_marginStart="6dp">
                <TextView
                    android:id="@+id/tv_win_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0s"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/win_time"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Next puzzle button (full width) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/BtnPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_next"
            android:layout_marginBottom="12dp" />

        <!-- Replay button (full width, outlined) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_replay"
            style="@style/BtnSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_replay" />

    </LinearLayout>

</FrameLayout>
