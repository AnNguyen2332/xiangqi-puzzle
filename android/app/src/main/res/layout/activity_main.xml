<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ── 将 watermark — behind everything ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&#x5C07;"
        android:textSize="240sp"
        android:textColor="#28cc2020"
        android:fontFamily="serif"
        android:layout_gravity="top|end"
        android:translationX="60dp"
        android:translationY="-20dp" />

    <!-- ── Content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <!-- Spacer top -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="2" />

        <!-- Hero title — LEFT aligned -->
        <TextView
            android:id="@+id/tv_title_co"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cờ"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/tv_title_the"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thế"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="@color/accent_red"
            android:fontFamily="serif"
            android:layout_marginTop="-12dp" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_subtitle"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.3"
            android:layout_marginTop="2dp" />

        <!-- Spacer middle -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Stats card -->
        <LinearLayout
            android:id="@+id/stats_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_solved"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_solved"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="44dp"
                android:background="@color/divider"
                android:layout_gravity="center_vertical" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_accuracy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_accuracy"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="44dp"
                android:background="@color/divider"
                android:layout_gravity="center_vertical" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_stat_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stat_streak"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Spacer -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <!-- Buttons — full width -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            style="@style/BtnPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_start" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            style="@style/BtnSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_continue"
            android:visibility="gone"
            android:layout_marginTop="12dp" />

        <!-- Spacer bottom -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1.5" />

    </LinearLayout>

</FrameLayout>
